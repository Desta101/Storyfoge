# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
#
# Story + character + comic panel generation (Google Gemini): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional; default gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash
# Optional image model for panel artwork; default imagen-3.0-generate-002
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
#
# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never expose to the client
SUPABASE_SERVICE_ROLE_KEY=
#
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Auth: set Site URL and add `${NEXT_PUBLIC_APP_URL}/auth/callback` to Redirect URLs (Supabase → Authentication → URL Configuration).
#
# Stripe (Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
